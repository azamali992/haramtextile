    "lenis": "^1.3.25",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^18",
    "react-dom": "^18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
