# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string used by Prisma (e.g. postgresql://user:password@host:5432/dbname)
DATABASE_URL="postgresql://user:password@localhost:5432/haram_textile"

# Random secret used by NextAuth.js to sign/encrypt session tokens and JWTs (generate with `openssl rand -base64 32`)
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Canonical URL NextAuth.js uses for callbacks (e.g. http://localhost:3000 in dev, https://haramtextile.com in production)
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary account cloud name, used to build upload/delivery URLs
CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Cloudinary API key for authenticated uploads from the admin panel
CLOUDINARY_API_KEY="your-api-key"

# Cloudinary API secret — keep this private, server-side only
CLOUDINARY_API_SECRET="your-api-secret"

# SMTP host used by Nodemailer to send contact-form notification emails
EMAIL_HOST="smtp.example.com"

# SMTP port for the mail server (commonly 587 for TLS or 465 for SSL)
EMAIL_PORT="587"

# SMTP username/login used to authenticate with the mail server
EMAIL_USER="your-smtp-username"

# SMTP password or app-specific password used to authenticate with the mail server
EMAIL_PASS="your-smtp-password"

# Destination inbox that receives contact/inquiry form submissions
EMAIL_TO="sales@haramtextile.com"

# Public base URL of the site, used for absolute links, sitemaps, and metadata (no trailing slash)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional: Google Analytics measurement ID — leave blank to disable analytics
NEXT_PUBLIC_GA_ID=""

# Optional: credentials for the single admin user created by `prisma/seed.ts`.
# If omitted, the seed script falls back to a clearly-labeled placeholder
# email/password (see prisma/seed.ts) that you MUST change after first login.
ADMIN_SEED_EMAIL="admin@haramtextile.com"
ADMIN_SEED_PASSWORD="change-this-before-deploying"
